<?xml version="1.0" encoding="utf-8"?>
<!-- A declaração acima DEVE ser sempre a primeira linha do arquivo -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <!-- TÍTULO: TextView para exibição de texto estático -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculadora de Viagem"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp" />

    <!-- ENTRADA: Distância (ID: editDistancia) -->
    <EditText
        android:id="@+id/editDistancia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Distância total (km)"
        android:inputType="numberDecimal" />

    <!-- ENTRADA: Preço do Litro (ID: editPrecoLitro) -->
    <EditText
        android:id="@+id/editPrecoLitro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Preço do Litro (R$)"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp" />

    <!-- ENTRADA: Consumo (ID: editConsumo) -->
    <EditText
        android:id="@+id/editConsumo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Consumo Médio (km/l)"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp" />

    <!-- AÇÃO: Botão para disparar o cálculo (ID: btnCalcular) -->
    <Button
        android:id="@+id/btnCalcular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calcular Custo"
        android:layout_marginTop="20dp" />

    <!-- RESULTADO: Exibição do valor calculado (ID: txtResultado) -->
    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Custo Estimado: R$ 0,00"
        android:textSize="20sp"
        android:layout_marginTop="30dp"
        android:textColor="#2E7D32"
        android:textStyle="bold"
        android:textAlignment="center" />

</LinearLayout>